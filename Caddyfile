# Caddyfile
# Автоматический HTTPS, reverse proxy для frontend/backend

{
    email ${LETSENCRYPT_EMAIL:-admin@focusflowbox.ru}
    on_demand_tls {
        ask http://backend:8000/api/health
    }

    # 🔐 Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    
    # 🗜️ Включить сжатие
    encode zstd gzip
}

# Основной домен
{$DOMAIN_NAME:localhost} {
    # API запросы → backend
    reverse_proxy /api/* backend:8000

    # S3 pre-signed URLs (если используется локальный MinIO в dev)
    reverse_proxy /s3/* minio:9000

    # Health check для Caddy on-demand TLS
    #handle /api/health {
    #    reverse_proxy backend:8000
    #}

    # Всё остальное → Next.js frontend
    reverse_proxy frontend:3000

    # Логирование (опционально)
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Локальная разработка без HTTPS (опционально)
#:80 {
#    reverse_proxy /api/* backend:8000
#    reverse_proxy frontend:3000
#}
