# .env.example — скопируйте в .env и заполните реальными значениями

# ── Domain & TLS ─────────────────────────────────────
DOMAIN_NAME=yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Images (для локального запуска, опционально)
FRONTEND_IMAGE=ghcr.io/pobisk/focusflow-frontend
BACKEND_IMAGE=ghcr.io/pobisk/focusflow-backend

# ── Database ─────────────────────────────────────────
DB_USER=focusflow
DB_PASSWORD=change_me_strong_password_!
DB_NAME=focusflow_db

# ── Redis ────────────────────────────────────────────
# (для APScheduler не обязателен, но нужен для Celery в будущем)

# ── S3 Storage ───────────────────────────────────────
# Для локального MinIO (dev):
S3_BUCKET=focusflow
S3_REGION=auto
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your_minio_key
S3_SECRET_KEY=your_minio_secret

# Для продакшена (AWS S3 / Cloudflare R2) замените значения выше:
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=focusflow-prod
# S3_REGION=auto
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# ── Application ──────────────────────────────────────
ENVIRONMENT=production  # или development
LOG_LEVEL=INFO
NEXT_PUBLIC_API_URL=/api

# ── Security ─────────────────────────────────────────
SECRET_KEY=generate_strong_random_string_32_chars_min
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
