# ── Application ──────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://focusflow:change_me@localhost:5432/focusflow_db

# ── Scheduler ────────────────────────────────────────
# APScheduler использует ту же БД, отдельные настройки не нужны

# ── S3 Storage ───────────────────────────────────────
S3_ENDPOINT=http://localhost:9000          # MinIO для dev
S3_BUCKET=focusflow-files
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password_strong

# ── Security ─────────────────────────────────────────
SECRET_KEY=change_me_generate_with_secrets_token_urlsafe_32

# ── CORS (для локальной разработки) ──────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
